# Spotify — server-side credentials (never exposed to the client)
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# Supabase — use the service role key (bypasses RLS for server writes)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# Port (Railway sets this automatically; leave unset for local dev)
# PORT=3000
